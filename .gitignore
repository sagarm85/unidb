/target
# Local engine/server data. The server now defaults to /tmp/unidb, but this
# stays as a guard in case UNIDB_DATA_DIR is pointed back into the tree.
/unidb-data

# Claude Code: commit shared settings.json, ignore the personal/local overrides
# (machine-specific permission grants — session paths, PIDs, local psql, etc.)
.claude/settings.local.json

# Editor / IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store

# Scratch bench/measurement logs (kept out of the tree; the durable numbers live
# in PROGRESS.md and the generated report under docs/performance/)
*.log
*.err

# Python bytecode (bench report tooling)
__pycache__/
*.pyc

# Dated benchmark reports under docs/performance/ ARE committed (kept as the
# measurement record). Only Docker-run output stays ignored (docker/out/ below).

# Generated Docker report output (reports, logs, phase/stats CSVs from
# scripts/report.sh --docker). The docker/ image + compose files ARE committed;
# only their run output under docker/out/ is not.
/docker/out/
